# Copy to .env and fill. .env is gitignored.

# --- eBay Browse API ---
# Register an app at https://developer.ebay.com/my/keys
# Production keys (not sandbox) for real listings.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# --- PriceCharting Premium API ---
# https://www.pricecharting.com/api-documentation
# $10/mo subscription required.
PRICECHARTING_API_KEY=

# --- TCGPlayer affiliate feed ---
# Sign up at https://partner.tcgplayer.com/
TCGPLAYER_AFFILIATE_ID=
TCGPLAYER_PRICE_FEED_URL=

# --- Pokemon TCG API ---
# Optional - free key raises rate limit from 1k/day to 20k/day.
# https://dev.pokemontcg.io/
POKEMON_TCG_API_KEY=

# --- Output ---
VAULT_OPPORTUNITIES_DIR=C:\Users\charl\Desktop\obi-secondbrain\opportunities

# --- Scout: price band ---
# 2026-04-28 market snapshot recommends $10 floor; trackable Pokemon
# mispricings cluster in the $10-$200 band.
SCOUT_PRICE_MIN=10
SCOUT_PRICE_MAX=200

# --- Scout: edge thresholds ---
# Per-category alpha thresholds from the 2026-04-28 market snapshot:
#   - Pokemon mature singles: 0-8% spread typical, >12% unusual.
#     v1 alpha threshold: 15%.
#   - One Piece: 5-50% spreads common with daily drift.
#     v1 alpha threshold: 25%.
SCOUT_MIN_EDGE_DOLLARS=5
SCOUT_MIN_EDGE_PCT=0.10
SCOUT_MIN_EDGE_PCT_POKEMON=0.15
SCOUT_MIN_EDGE_PCT_ONE_PIECE=0.25
SCOUT_MIN_CONFIDENCE=0.4

# --- eBay categories ---
# 2611 = Pokemon TCG. Add more (comma-separated) to widen the scan.
SCOUT_EBAY_CATEGORY_IDS=2611
