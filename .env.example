# Copy to .env and fill. .env is gitignored.

# --- eBay Browse API ---
# Register an app at https://developer.ebay.com/my/keys
# Production keys (not sandbox) for real listings.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# OAuth token gets refreshed automatically; no need to set here.
# EBAY_OAUTH_TOKEN_CACHE=.cache/ebay_token.json

# --- PriceCharting Premium API ---
# https://www.pricecharting.com/api-documentation
# $10/mo subscription required.
PRICECHARTING_API_KEY=

# --- TCGPlayer affiliate feed ---
# Sign up at https://partner.tcgplayer.com/
# The daily price-export feed download URL gets rotated; check your dashboard.
TCGPLAYER_AFFILIATE_ID=
TCGPLAYER_PRICE_FEED_URL=

# --- Pokemon TCG API ---
# Optional — increases rate limit from 1k/day to 20k/day. Free.
# https://dev.pokemontcg.io/
POKEMON_TCG_API_KEY=

# --- Output ---
# Where opportunity notes get written. Default = the second brain vault.
VAULT_OPPORTUNITIES_DIR=C:\Users\charl\Desktop\obi-secondbrain\opportunities

# --- Scout configuration ---
# Price band to focus on (USD).
SCOUT_PRICE_MIN=30
SCOUT_PRICE_MAX=200

# Edge thresholds — only surface opportunities above these.
SCOUT_MIN_EDGE_DOLLARS=5
SCOUT_MIN_EDGE_PCT=0.10
SCOUT_MIN_CONFIDENCE=0.4

# Categories to scan (eBay category IDs).
# 2611 = Trading Card Games > Collectible Card Games > Pokémon TCG
# Find more at https://www.ebay.com/help/selling/listings/categories-mappings
SCOUT_EBAY_CATEGORY_IDS=2611
